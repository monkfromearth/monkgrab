{
  "manifest_version": 3,
  "name": "MonkGrab",
  "version": "1.0.0",
  "description": "Save any webpage as clean Markdown in one click, including content locked inside cross-origin iframes that other tools miss.",
  "author": "monkfromearth",
  "homepage_url": "https://monkfrom.earth",
  "minimum_chrome_version": "102",
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "MonkGrab — save page as Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "grab": {
      "suggested_key": { "default": "Ctrl+Shift+G", "mac": "Command+Shift+G" },
      "description": "MonkGrab: save the current page as Markdown"
    }
  }
}
